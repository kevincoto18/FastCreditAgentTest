        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"status\": {\n      \"type\": \"string\",\n      \"enum\": [\n        \"APPROVED\",\n        \"FLAGGED_FOR_REVIEW\",\n        \"MISSING_DATA\"\n      ],\n      \"description\": \"The final decision based on internal policies. APPROVED if all rules pass, FLAGGED_FOR_REVIEW if flags are triggered, and MISSING_DATA if information is incomplete.\"\n    },\n    \"policy_reference\": {\n      \"type\": \"string\",\n      \"description\": \"The specific Policy ID found in the retrieved document (e.g., POL-2024-001). This proves the agent consulted the manual.\"\n    },\n    \"full_analysis\": {\n      \"type\": \"string\",\n      \"description\": \"A detailed explanation of why the application was approved or flagged, mentioning specific policy matches or violations found in the retrieved documentation.\"\n    },\n    \"applicant_metadata\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"name\": {\n          \"type\": \"string\",\n          \"description\": \"Full name of the applicant.\"\n        },\n        \"age\": {\n          \"type\": \"integer\",\n          \"description\": \"Age of the applicant in years.\"\n        },\n        \"loan_amount\": {\n          \"type\": \"number\",\n          \"description\": \"The total loan amount requested.\"\n        },\n        \"income\": {\n          \"type\": \"number\",\n          \"description\": \"Monthly gross income of the applicant.\"\n        },\n        \"employment_tenure_months\": {\n          \"type\": \"integer\",\n          \"description\": \"Total months at the current job.\"\n        }\n      },\n      \"required\": [\n        \"name\",\n        \"age\",\n        \"loan_amount\",\n        \"income\",\n        \"employment_tenure_months\"\n      ]\n    },\n    \"flags_detected\": {\n      \"type\": \"boolean\",\n      \"description\": \"True if any risk flags (high debt, high amount) were triggered according to the policy.\"\n    }\n  },\n  \"required\": [\n    \"status\",\n    \"policy_reference\",\n    \"full_analysis\",\n    \"applicant_metadata\",\n    \"flags_detected\"\n  ]\n}"
      },
