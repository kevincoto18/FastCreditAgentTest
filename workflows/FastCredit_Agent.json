        "message": "=<div style=\"font-family: Arial, sans-serif; color: #333; max-width: 600px; border: 1px solid #e0e0e0; border-radius: 8px; padding: 20px;\">\n  <h2 style=\"color: #2e7d32;\">Loan Application Approved!</h2>\n  <p>Dear Applicant,</p>\n  <p>We are pleased to inform you that your credit application has been <b>automatically approved</b> after successfully passing our initial verification process.</p>\n  \n  <div style=\"background-color: #f9f9f9; padding: 15px; border-left: 4px solid #2e7d32; margin: 20px 0;\">\n    <strong>Status:</strong> Approved <br>\n    <strong>Next Steps:</strong> Our financial team will contact you within 24 hours to finalize the disbursement.\n  </div>\n  \n  <p>Thank you for choosing <b>FastCredit</b>.</p>\n  <hr style=\"border: 0; border-top: 1px solid #eee;\">\n  <p style=\"font-size: 12px; color: #888;\">This is an automated message. Please do not reply directly to this email.</p>\n</div>",
