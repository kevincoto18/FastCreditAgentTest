        "messageId": "={{ $('Gmail Trigger').item.json.id }}",
        "message": "=<div style=\"font-family: Arial, sans-serif; color: #333; max-width: 600px; border: 1px solid #e0e0e0; border-radius: 8px; padding: 20px;\">\n  <h2 style=\"color: #ef6c00;\">Action Required: Missing Attachment</h2>\n  <p>Hello,</p>\n  <p>We received your email regarding a <b>Credit Request</b>, but we couldn't find the required PDF application form attached to your message.</p>\n  \n  <div style=\"background-color: #fff3e0; padding: 15px; border-left: 4px solid #ef6c00; margin: 20px 0;\">\n    <strong>Issue:</strong> No PDF document detected. <br>\n    <strong>Next Step:</strong> Please reply to this email or send a new one including your <b>Loan Application PDF</b> so our AI system can process it immediately.\n  </div>\n  \n  <p>If you have any questions, feel free to contact our support team.</p>\n  <p>Best regards,<br><b>FastCredit Automation Team</b></p>\n  <hr style=\"border: 0; border-top: 1px solid #eee;\">\n  <p style=\"font-size: 12px; color: #888;\">Note: Our system only processes requests that include a valid PDF attachment.</p>\n</div>",
        "options": {}
      },
